{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MailPilot",
  "mainBinaryName": "MailPilot",
  "version": "../package.json",
  "identifier": "com.mailpilot.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File ..\\tools\\prepare-desktop-build.ps1",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MailPilot",
        "width": 1320,
        "height": 840,
        "minWidth": 1024,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "publisher": "MailPilot",
    "homepage": "https://github.com/T-h07/MailPilot",
    "copyright": "Copyright (c) MailPilot",
    "category": "Productivity",
    "shortDescription": "Desktop workspace for Gmail triage, focus queues, and analytics.",
    "longDescription": "MailPilot is a Windows desktop workspace for Gmail that combines inbox triage, focus queues, exports, and analytics in one installable Tauri application backed by the existing Spring API.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/backend/mailpilot-server.jar": "backend/mailpilot-server.jar"
    },
    "windows": {
      "allowDowngrades": false,
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "startMenuFolder": "MailPilot"
      }
    }
  }
}
